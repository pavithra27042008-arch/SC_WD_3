*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial;
}

body{
background:#1b1b32;
display:flex;
justify-content:center;
align-items:center;
height:100vh;
}

.container{
width:500px;
background:white;
padding:25px;
border-radius:10px;
box-shadow:0 0 10px rgba(0,0,0,.3);
}

h1{
text-align:center;
margin-bottom:20px;
}

#question{
margin-bottom:20px;
}

.btn{
width:100%;
padding:12px;
margin:8px 0;
border:none;
background:#ddd;
cursor:pointer;
border-radius:5px;
font-size:16px;
}

.btn:hover{
background:#cfcfcf;
}

.correct{
background:green;
color:white;
}

.incorrect{
background:red;
color:white;
}

#next-btn{
display:none;
margin-top:20px;
padding:12px;
width:100%;
background:#1b1b32;
color:white;
border:none;
cursor:pointer;
border-radius:5px;
}